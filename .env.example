# GEODHA Environment Variables — copy to .env and fill in real values
# NEVER commit .env to git. All secrets are stored in GitHub Secrets / CI environment variables.

# ── Firebase Configuration ──
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_VAPID_KEY=your_vapid_key_for_push_notifications

# ── Blog ──
# Notion embed URL for the /blog page.
# If not set, falls back to the default Notion workspace URL.
VITE_BLOG_NOTION_URL=https://glen-hammer-7bb.notion.site/ebd/1abc5691405e80baa346dcda909b50f0

# ── Report Form ──
# External form URL for /report page submissions.
# If set, the form redirects here on submit instead of the placeholder handler.
# TODO: wire to Firebase reporting pipeline — remove this env var when pipeline is live.
VITE_REPORT_FORM_URL=

# ── Optional: Google Maps API (not currently used — Leaflet/OSM is default) ──
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
